{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["bun"]
  },
  "include": ["src/**/*", "tests/**/*", "vite.config.ts"]
}
